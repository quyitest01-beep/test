# 服务器配置
PORT=8000
NODE_ENV=development

# 数据库配置
# 支持的数据库类型: mysql, postgresql, sqlite, sqlserver, oracle
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=athena_query
DB_CONNECTION_LIMIT=10
DB_SSL=false
DB_TIMEOUT=30000

# SQLite配置 (当DB_TYPE=sqlite时使用)
DB_SQLITE_PATH=./database/data.sqlite

# PostgreSQL配置 (当DB_TYPE=postgresql时使用)
DB_POSTGRES_SCHEMA=public

# SQL Server配置 (当DB_TYPE=sqlserver时使用)
DB_SQLSERVER_ENCRYPT=true
DB_SQLSERVER_TRUST_CERT=true

# Oracle配置 (当DB_TYPE=oracle时使用)
DB_ORACLE_SERVICE_NAME=ORCL

# AWS配置 (需要用户填写真实凭证)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Athena配置
ATHENA_DATABASE=default
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_LOCATION=s3://your-athena-results-bucket/

# S3配置
S3_RESULTS_BUCKET=your-athena-results-bucket

# 查询配置
QUERY_TIMEOUT=300000
MAX_CONCURRENT_QUERIES=5
MAX_QUERY_COST=100

# 成本控制
COST_ALERT_THRESHOLD=50
DAILY_COST_LIMIT=500

# 日志配置
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_MAX_FILES=5