{
  "nodes": [
    {
      "parameters": {
        "method": "POST",
        "url": "https://open.larksuite.com/open-apis/sheets/v2/spreadsheets/{{ $json.spreadsheet_token }}/sheets_batch_update",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.lark_token }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json; charset=utf-8"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "requests",
              "value": "=[{\"addSheet\":{\"properties\":{\"title\":\"{{ $json.table_name }}\",\"index\":0}}}]"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2500,
        100
      ],
      "id": "lark-create-sheet",
      "name": "创建Lark工作表"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://open.larksuite.com/open-apis/sheets/v2/spreadsheets/{{ $json.spreadsheet_token }}/values_batch_update",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $json.lark_token }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json; charset=utf-8"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "valueRange",
              "value": "={{ JSON.stringify({ range: $json.table_name + '!A1:H' + ($json.lark_data.total_rows + 1), values: [$json.lark_data.headers, ...$json.lark_data.rows] }) }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2700,
        100
      ],
      "id": "lark-insert-data",
      "name": "写入Lark数据"
    }
  ],
  "connections": {
    "创建Lark工作表": {
      "main": [
        [
          {
            "node": "写入Lark数据",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}







