# 服务器配置
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=athena_admin
DB_CONNECTION_LIMIT=10

# JWT认证配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# 密码策略配置
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_SPECIAL=true
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30

# AWS配置
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Athena配置
ATHENA_DATABASE=your_database_name
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_LOCATION=s3://your-athena-results-bucket/

# S3配置
S3_RESULTS_BUCKET=your-athena-results-bucket

# 查询配置
MAX_QUERY_TIMEOUT=300000
MAX_RESULT_SIZE=1000000
DEFAULT_PAGE_SIZE=1000

# 成本控制
MAX_QUERY_COST=10.00
COST_ALERT_THRESHOLD=5.00

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/query-system.log