{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "业务数据报告输出格式",
  "description": "AI Agent输出的业务数据报告JSON格式",
  "required": ["markdown"],
  "properties": {
    "markdown": {
      "type": "string",
      "description": "完整的Markdown格式报告内容，包含所有章节、表格和小结",
      "minLength": 100
    },
    "reportType": {
      "type": "string",
      "enum": ["weekly", "monthly", "daily"],
      "description": "报告类型：周报、月报、日报"
    },
    "currentPeriod": {
      "type": "string",
      "pattern": "^\\d{8}(-\\d{4,8})?$",
      "description": "当前周期标识，格式：YYYYMMDD-YYYYMMDD 或 YYYYMM"
    },
    "previousPeriod": {
      "type": "string",
      "pattern": "^\\d{8}(-\\d{4,8})?$",
      "description": "上期周期标识，格式：YYYYMMDD-YYYYMMDD 或 YYYYMM"
    },
    "metadata": {
      "type": "object",
      "description": "报告元数据",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "报告生成时间（ISO 8601格式）"
        },
        "hasNewGames": {
          "type": "boolean",
          "description": "是否包含新游戏数据"
        },
        "periodType": {
          "type": "string",
          "enum": ["weekly", "monthly"],
          "description": "周期类型"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

