{
  "type": "object",
  "properties": {
    "markdown": {
      "type": "string",
      "description": "完整的Markdown格式业务分析报告文本内容，必须包含所有章节、表格和小结。这是最重要的字段，必须包含完整的报告内容。"
    },
    "reportType": {
      "type": "string",
      "enum": ["weekly", "daily", "monthly"],
      "description": "报告类型，根据数据周期判断：weekly（周报）、daily（日报）、monthly（月报）"
    },
    "currentPeriod": {
      "type": "string",
      "description": "当前周期，格式：20251027-20251102 或 10.27-11.02。如果无法确定，可以使用空字符串。"
    },
    "previousPeriod": {
      "type": "string",
      "description": "上一周期，格式：20251020-20251026 或 10.20-10.26。如果无法确定，可以使用空字符串。"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "description": "报告生成时间，ISO格式字符串，如：2025-11-05T04:16:49.898Z"
        },
        "hasNewGames": {
          "type": "boolean",
          "description": "是否有新游戏，true表示有新游戏，false表示没有"
        }
      },
      "additionalProperties": true
    }
  },
  "required": ["markdown"],
  "additionalProperties": true
}

