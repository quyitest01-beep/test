{
  "template_info": {
    "name": "Lark应用机器人场景模板",
    "version": "1.0.0",
    "description": "飞书机器人智能数据查询场景配置模板",
    "platform": "lark",
    "created_date": "2024-01-15",
    "last_updated": "2024-01-15"
  },
  "scenarios": [
    {
      "id": "lark_sales_analysis",
      "name": "销售数据分析",
      "description": "通过Lark机器人查询销售业绩数据",
      "trigger_patterns": [
        "/query 销售数据",
        "@机器人 销售分析",
        "查看销售业绩"
      ],
      "interaction_flow": {
        "step1": {
          "type": "card_form",
          "title": "销售数据查询",
          "fields": [
            {
              "name": "time_range",
              "label": "时间范围",
              "type": "date_range_picker",
              "required": true,
              "default": "last_30_days"
            },
            {
              "name": "sales_region",
              "label": "销售区域",
              "type": "multi_select",
              "options": ["华北", "华东", "华南", "西南", "全国"],
              "default": ["全国"]
            },
            {
              "name": "product_category",
              "label": "产品类别",
              "type": "select",
              "options": ["全部", "电子产品", "服装", "食品", "其他"]
            }
          ],
          "submit_button": {
            "text": "开始查询",
            "style": "primary"
          }
        },
        "step2": {
          "type": "confirmation_card",
          "title": "查询参数确认",
          "content": "时间范围: {time_range}\n销售区域: {sales_region}\n产品类别: {product_category}",
          "buttons": [
            {"text": "确认查询", "action": "confirm", "style": "primary"},
            {"text": "重新设置", "action": "reset", "style": "default"}
          ]
        },
        "step3": {
          "type": "progress_card",
          "title": "正在查询销售数据...",
          "progress_steps": [
            "连接数据库",
            "执行查询",
            "数据处理",
            "生成报告"
          ]
        },
        "step4": {
          "type": "result_card",
          "title": "销售数据分析结果",
          "summary_fields": [
            {"label": "总销售额", "value": "{total_sales}", "format": "currency"},
            {"label": "订单数量", "value": "{order_count}", "format": "number"},
            {"label": "平均客单价", "value": "{avg_order_value}", "format": "currency"}
          ],
          "chart_preview": {
            "type": "line_chart",
            "title": "销售趋势图",
            "data_source": "sales_trend_data"
          },
          "action_buttons": [
            {"text": "下载详细报告", "action": "download_excel"},
            {"text": "在线查看图表", "action": "view_charts"},
            {"text": "分享到群组", "action": "share_to_group"}
          ]
        }
      },
      "sql_template": "SELECT region, product_category, SUM(sales_amount) as total_sales, COUNT(*) as order_count FROM sales_data WHERE date_created BETWEEN '{start_date}' AND '{end_date}' {region_filter} {category_filter} GROUP BY region, product_category ORDER BY total_sales DESC",
      "response_format": {
        "type": "structured_card",
        "include_chart": true,
        "export_formats": ["excel", "pdf", "csv"]
      }
    },
    {
      "id": "lark_user_behavior",
      "name": "用户行为分析",
      "description": "分析用户活跃度和行为模式",
      "trigger_patterns": [
        "/query 用户行为",
        "用户活跃度分析",
        "@机器人 用户数据"
      ],
      "interaction_flow": {
        "step1": {
          "type": "card_form",
          "title": "用户行为分析",
          "fields": [
            {
              "name": "analysis_period",
              "label": "分析周期",
              "type": "select",
              "options": ["最近7天", "最近30天", "最近90天", "自定义"]
            },
            {
              "name": "user_segment",
              "label": "用户群体",
              "type": "multi_select",
              "options": ["新用户", "活跃用户", "沉默用户", "流失用户"]
            },
            {
              "name": "behavior_metrics",
              "label": "行为指标",
              "type": "checkbox_group",
              "options": ["登录频次", "页面浏览", "功能使用", "停留时长"]
            }
          ]
        },
        "step2": {
          "type": "result_card",
          "title": "用户行为分析报告",
          "metrics_display": [
            {"label": "活跃用户数", "value": "{active_users}"},
            {"label": "平均会话时长", "value": "{avg_session_duration}"},
            {"label": "用户留存率", "value": "{retention_rate}"}
          ],
          "visualization": {
            "type": "multi_chart",
            "charts": [
              {"type": "pie", "title": "用户分布"},
              {"type": "bar", "title": "行为指标对比"}
            ]
          }
        }
      },
      "sql_template": "SELECT user_segment, COUNT(DISTINCT user_id) as user_count, AVG(session_duration) as avg_duration FROM user_behavior WHERE date >= '{start_date}' {segment_filter} GROUP BY user_segment",
      "response_format": {
        "type": "analytics_card",
        "include_visualization": true
      }
    },
    {
      "id": "lark_inventory_check",
      "name": "库存查询",
      "description": "快速查询产品库存状态",
      "trigger_patterns": [
        "/inventory",
        "库存查询",
        "@机器人 库存"
      ],
      "interaction_flow": {
        "step1": {
          "type": "quick_form",
          "title": "库存查询",
          "fields": [
            {
              "name": "product_code",
              "label": "产品编码",
              "type": "text_input",
              "placeholder": "输入产品编码或名称"
            },
            {
              "name": "warehouse",
              "label": "仓库",
              "type": "select",
              "options": ["全部仓库", "北京仓", "上海仓", "广州仓"]
            }
          ]
        },
        "step2": {
          "type": "inventory_card",
          "title": "库存信息",
          "product_info": {
            "name": "{product_name}",
            "code": "{product_code}",
            "category": "{category}"
          },
          "stock_details": [
            {"warehouse": "{warehouse_name}", "quantity": "{stock_quantity}", "status": "{stock_status}"}
          ],
          "alert_info": {
            "low_stock_threshold": "{threshold}",
            "alert_level": "{alert_level}"
          }
        }
      },
      "sql_template": "SELECT p.product_name, p.product_code, i.warehouse, i.quantity, i.reserved_quantity FROM products p JOIN inventory i ON p.id = i.product_id WHERE p.product_code LIKE '%{product_code}%' {warehouse_filter}",
      "response_format": {
        "type": "inventory_status_card",
        "show_alerts": true
      }
    }
  ],
  "global_settings": {
    "default_language": "zh-CN",
    "timezone": "Asia/Shanghai",
    "date_format": "YYYY-MM-DD",
    "currency_format": "CNY",
    "number_format": "#,##0.00"
  },
  "card_styles": {
    "primary_color": "#1890ff",
    "success_color": "#52c41a",
    "warning_color": "#faad14",
    "error_color": "#f5222d",
    "font_family": "PingFang SC, Microsoft YaHei",
    "border_radius": "6px"
  },
  "error_handling": {
    "network_error": {
      "message": "网络连接异常，请稍后重试",
      "retry_button": true
    },
    "data_error": {
      "message": "数据查询失败，请检查查询条件",
      "contact_admin": true
    },
    "permission_error": {
      "message": "您没有权限执行此操作，请联系管理员",
      "show_help": true
    }
  },
  "help_content": {
    "quick_start": {
      "title": "快速开始",
      "steps": [
        "1. 使用斜杠命令 /query 开始查询",
        "2. 填写查询表单并提交",
        "3. 确认查询参数",
        "4. 查看结果并下载报告"
      ]
    },
    "available_commands": [
      "/query - 开始数据查询",
      "/inventory - 库存查询",
      "/help - 查看帮助",
      "/status - 查看查询状态"
    ],
    "contact_info": {
      "admin_contact": "@系统管理员",
      "support_group": "数据查询支持群"
    }
  }
}