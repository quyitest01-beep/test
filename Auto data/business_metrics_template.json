{
  "template_id": "business_metrics_report",
  "name": "业务指标报表生成",
  "description": "生成包含多个业务指标的定期报表，支持自动化调度和邮件发送",
  "version": "1.0",
  "category": "report_generation",
  
  "text_parsing_rules": {
    "patterns": [
      {
        "pattern": "(月活|日活|留存|净营收).*?(月报|周报|日报).*?(发送|生成)",
        "description": "匹配业务指标报表生成需求",
        "parameter_mapping": {
          "metrics": ["MAU", "DAU", "retention", "net_revenue"],
          "report_period": "monthly",
          "auto_send": true
        }
      },
      {
        "pattern": "([^，,]+)这几个指标.*?(月报|周报|日报)",
        "description": "匹配指定指标的报表需求",
        "parameter_mapping": {
          "metrics_text": "{1}",
          "report_period": "{2}"
        }
      },
      {
        "pattern": "生成.*?(月报|周报|日报).*?包含.*?([^。]+)",
        "description": "匹配报表生成需求",
        "parameter_mapping": {
          "report_period": "{1}",
          "metrics_text": "{2}"
        }
      }
    ],
    
    "metric_aliases": {
      "MAU": ["月活", "月活跃用户", "月活用户数", "Monthly Active Users"],
      "DAU": ["日活", "日活跃用户", "日活用户数", "Daily Active Users"],
      "retention": ["留存", "留存率", "用户留存", "retention rate"],
      "net_revenue": ["净营收", "净收入", "净利润", "net revenue"],
      "ARPU": ["ARPU", "平均收入", "用户平均收入", "Average Revenue Per User"],
      "LTV": ["LTV", "用户生命周期价值", "Life Time Value"],
      "conversion_rate": ["转化率", "转换率", "conversion rate"],
      "churn_rate": ["流失率", "用户流失率", "churn rate"]
    },
    
    "period_aliases": {
      "daily": ["日报", "每日", "天"],
      "weekly": ["周报", "每周", "星期"],
      "monthly": ["月报", "每月", "月"]
    }
  },
  
  "parameters": {
    "metrics": {
      "type": "array",
      "required": true,
      "description": "业务指标列表",
      "allowed_values": ["MAU", "DAU", "retention", "net_revenue", "ARPU", "LTV", "conversion_rate", "churn_rate"],
      "min_items": 1,
      "max_items": 8
    },
    "report_period": {
      "type": "enum",
      "required": true,
      "description": "报表周期",
      "allowed_values": ["daily", "weekly", "monthly"],
      "default": "monthly"
    },
    "auto_send": {
      "type": "boolean",
      "required": false,
      "description": "是否自动发送",
      "default": false
    },
    "recipients": {
      "type": "array",
      "required": false,
      "description": "报表接收人邮箱列表",
      "item_type": "email",
      "default": []
    },
    "date_range": {
      "type": "object",
      "required": false,
      "description": "自定义日期范围",
      "properties": {
        "start_date": {"type": "date"},
        "end_date": {"type": "date"}
      }
    }
  },
  
  "database_config": {
    "tables": {
      "user_activities": "用户活动记录表",
      "user_cohort_analysis": "用户群组分析表",
      "revenue_records": "收入记录表",
      "user_profiles": "用户档案表",
      "conversion_events": "转化事件表"
    },
    "indexes": ["user_id", "created_at", "event_date", "cohort_month"]
  },
  
  "query_templates": {
    "MAU": {
      "description": "月活跃用户数",
      "query": "SELECT COUNT(DISTINCT user_id) as mau, DATE_FORMAT(created_at, '%Y-%m') as month FROM user_activities WHERE created_at >= DATE_SUB(CURDATE(), INTERVAL 12 MONTH) GROUP BY DATE_FORMAT(created_at, '%Y-%m') ORDER BY month",
      "result_format": {"metric_name": "MAU", "value": "mau", "period": "month"}
    },
    "DAU": {
      "description": "日活跃用户数",
      "query": "SELECT COUNT(DISTINCT user_id) as dau, DATE(created_at) as date FROM user_activities WHERE created_at >= DATE_SUB(CURDATE(), INTERVAL 30 DAY) GROUP BY DATE(created_at) ORDER BY date",
      "result_format": {"metric_name": "DAU", "value": "dau", "period": "date"}
    },
    "retention": {
      "description": "用户留存率",
      "query": "SELECT cohort_month, period_number, COUNT(DISTINCT user_id) as retained_users, FIRST_VALUE(COUNT(DISTINCT user_id)) OVER (PARTITION BY cohort_month ORDER BY period_number) as cohort_size, COUNT(DISTINCT user_id) / FIRST_VALUE(COUNT(DISTINCT user_id)) OVER (PARTITION BY cohort_month ORDER BY period_number) * 100 as retention_rate FROM user_cohort_analysis WHERE cohort_month >= DATE_SUB(CURDATE(), INTERVAL 12 MONTH) GROUP BY cohort_month, period_number ORDER BY cohort_month, period_number",
      "result_format": {"metric_name": "retention", "value": "retention_rate", "period": "cohort_month"}
    },
    "net_revenue": {
      "description": "净营收",
      "query": "SELECT DATE(created_at) as date, SUM(revenue_amount - cost_amount) as net_revenue, SUM(revenue_amount) as gross_revenue, SUM(cost_amount) as total_cost FROM revenue_records WHERE created_at >= DATE_SUB(CURDATE(), INTERVAL 30 DAY) GROUP BY DATE(created_at) ORDER BY date",
      "result_format": {"metric_name": "net_revenue", "value": "net_revenue", "period": "date"}
    },
    "ARPU": {
      "description": "平均每用户收入",
      "query": "SELECT DATE_FORMAT(r.created_at, '%Y-%m') as month, SUM(r.revenue_amount) / COUNT(DISTINCT r.user_id) as arpu FROM revenue_records r WHERE r.created_at >= DATE_SUB(CURDATE(), INTERVAL 12 MONTH) GROUP BY DATE_FORMAT(r.created_at, '%Y-%m') ORDER BY month",
      "result_format": {"metric_name": "ARPU", "value": "arpu", "period": "month"}
    },
    "LTV": {
      "description": "用户生命周期价值",
      "query": "SELECT DATE_FORMAT(first_purchase_date, '%Y-%m') as cohort, AVG(total_revenue) as avg_ltv FROM (SELECT user_id, MIN(created_at) as first_purchase_date, SUM(revenue_amount) as total_revenue FROM revenue_records GROUP BY user_id) ltv_data WHERE first_purchase_date >= DATE_SUB(CURDATE(), INTERVAL 12 MONTH) GROUP BY DATE_FORMAT(first_purchase_date, '%Y-%m') ORDER BY cohort",
      "result_format": {"metric_name": "LTV", "value": "avg_ltv", "period": "cohort"}
    },
    "conversion_rate": {
      "description": "转化率",
      "query": "SELECT DATE(event_date) as date, COUNT(CASE WHEN event_type = 'conversion' THEN 1 END) / COUNT(*) * 100 as conversion_rate FROM conversion_events WHERE event_date >= DATE_SUB(CURDATE(), INTERVAL 30 DAY) GROUP BY DATE(event_date) ORDER BY date",
      "result_format": {"metric_name": "conversion_rate", "value": "conversion_rate", "period": "date"}
    },
    "churn_rate": {
      "description": "用户流失率",
      "query": "SELECT DATE_FORMAT(churn_date, '%Y-%m') as month, COUNT(*) as churned_users, (SELECT COUNT(DISTINCT user_id) FROM user_activities WHERE DATE_FORMAT(created_at, '%Y-%m') = DATE_FORMAT(churn_date, '%Y-%m')) as active_users, COUNT(*) / (SELECT COUNT(DISTINCT user_id) FROM user_activities WHERE DATE_FORMAT(created_at, '%Y-%m') = DATE_FORMAT(churn_date, '%Y-%m')) * 100 as churn_rate FROM user_churn_analysis WHERE churn_date >= DATE_SUB(CURDATE(), INTERVAL 12 MONTH) GROUP BY DATE_FORMAT(churn_date, '%Y-%m') ORDER BY month",
      "result_format": {"metric_name": "churn_rate", "value": "churn_rate", "period": "month"}
    }
  },
  
  "report_templates": {
    "monthly": {
      "template_file": "monthly_metrics_template.html",
      "sections": [
        {"title": "核心指标概览", "metrics": ["MAU", "net_revenue", "ARPU"]},
        {"title": "用户行为分析", "metrics": ["DAU", "retention", "churn_rate"]},
        {"title": "收入分析", "metrics": ["net_revenue", "LTV", "conversion_rate"]}
      ],
      "charts": [
        {"type": "line", "title": "月活趋势", "metric": "MAU"},
        {"type": "bar", "title": "净营收对比", "metric": "net_revenue"},
        {"type": "heatmap", "title": "留存率热力图", "metric": "retention"}
      ]
    },
    "weekly": {
      "template_file": "weekly_metrics_template.html",
      "sections": [
        {"title": "本周核心数据", "metrics": ["DAU", "net_revenue"]},
        {"title": "用户活跃度", "metrics": ["DAU", "conversion_rate"]}
      ]
    },
    "daily": {
      "template_file": "daily_metrics_template.html",
      "sections": [
        {"title": "今日数据", "metrics": ["DAU", "net_revenue", "conversion_rate"]}
      ]
    }
  },
  
  "automation_config": {
    "schedule_patterns": {
      "daily": "0 9 * * *",
      "weekly": "0 9 * * 1",
      "monthly": "0 9 1 * *"
    },
    "email_config": {
      "subject_template": "{report_period}业务指标报表 - {date}",
      "body_template": "请查收附件中的{report_period}业务指标报表。报表包含以下指标：{metrics_list}",
      "attachment_format": "pdf"
    },
    "retry_policy": {
      "max_retries": 3,
      "retry_interval": 300
    }
  },
  
  "export_rules": {
    "default_format": "pdf",
    "filename_template": "{report_period}_metrics_report_{date}.pdf",
    
    "pdf_config": {
      "page_size": "A4",
      "orientation": "portrait",
      "margins": {"top": 20, "bottom": 20, "left": 15, "right": 15},
      "header": {
        "text": "业务指标报表",
        "font_size": 16,
        "alignment": "center"
      },
      "footer": {
        "text": "生成时间：{timestamp} | 页码：{page_number}",
        "font_size": 10,
        "alignment": "center"
      }
    },
    
    "excel_config": {
      "sheets": [
        {"name": "指标汇总", "data_source": "metrics_summary"},
        {"name": "趋势分析", "data_source": "trend_data"},
        {"name": "原始数据", "data_source": "raw_data"}
      ]
    }
  },
  
  "response_format": {
    "success": {
      "status": "success",
      "message": "业务指标报表生成完成",
      "data": {
        "report_info": {
          "report_period": "{report_period}",
          "metrics": "{metrics}",
          "generation_time": "{timestamp}",
          "data_period": "{data_start_date} - {data_end_date}"
        },
        "metrics_summary": {},
        "report_file": {
          "filename": "{report_filename}",
          "download_url": "{download_url}",
          "file_size": "{file_size}"
        },
        "automation_status": {
          "auto_send_enabled": "{auto_send}",
          "next_generation": "{next_schedule}",
          "recipients": "{recipients}"
        }
      }
    },
    "error": {
      "status": "error",
      "message": "报表生成失败：{error_message}",
      "error_code": "{error_code}",
      "suggestions": []
    }
  },
  
  "example_inputs": [
    {
      "text": "月活，日活，留存，净营收这几个指标可以做成月报发送吗",
      "parsed_parameters": {
        "metrics": ["MAU", "DAU", "retention", "net_revenue"],
        "report_period": "monthly",
        "auto_send": true
      }
    },
    {
      "text": "生成包含ARPU和LTV的周报",
      "parsed_parameters": {
        "metrics": ["ARPU", "LTV"],
        "report_period": "weekly",
        "auto_send": false
      }
    },
    {
      "text": "每天自动发送转化率和流失率的日报给管理层",
      "parsed_parameters": {
        "metrics": ["conversion_rate", "churn_rate"],
        "report_period": "daily",
        "auto_send": true,
        "recipients": ["management@company.com"]
      }
    }
  ]
}