{
  "template_id": "time_range_data_query",
  "name": "时间范围数据查询",
  "description": "查询指定时间范围内的货币交易数据，支持多种货币类型和时间表达方式",
  "version": "1.0",
  "category": "data_query",
  
  "text_parsing_rules": {
    "patterns": [
      {
        "pattern": "(\\d+)号到(\\d+)号的([A-Z]{3})跟([A-Z]{3})数据",
        "description": "匹配'1号到31号的PHP跟INR数据'格式",
        "parameter_mapping": {
          "start_date": "2024-01-{1}",
          "end_date": "2024-01-{2}",
          "currencies": ["{3}", "{4}"]
        }
      },
      {
        "pattern": "我要(\\d+)月(\\d+)日到(\\d+)月(\\d+)日的([A-Z]{3}).*?数据",
        "description": "匹配具体日期范围格式",
        "parameter_mapping": {
          "start_date": "2024-{1}-{2}",
          "end_date": "2024-{3}-{4}",
          "currencies": ["{5}"]
        }
      },
      {
        "pattern": "(本月|上月|这个月)的([A-Z]{3}).*?数据",
        "description": "匹配相对时间表达",
        "parameter_mapping": {
          "time_period": "{1}",
          "currencies": ["{2}"]
        }
      }
    ],
    
    "currency_aliases": {
      "PHP": ["菲律宾比索", "比索", "菲币"],
      "INR": ["印度卢比", "卢比", "印币"],
      "USD": ["美元", "美金", "刀"],
      "CNY": ["人民币", "元", "中国元"],
      "THB": ["泰铢", "泰币"]
    },
    
    "time_expressions": {
      "本月": "current_month",
      "上月": "last_month",
      "这个月": "current_month",
      "上个月": "last_month",
      "今年": "current_year",
      "去年": "last_year"
    }
  },
  
  "parameters": {
    "start_date": {
      "type": "date",
      "required": true,
      "description": "查询开始日期",
      "format": "YYYY-MM-DD",
      "validation": {
        "min_date": "2020-01-01",
        "max_date": "today"
      }
    },
    "end_date": {
      "type": "date",
      "required": true,
      "description": "查询结束日期",
      "format": "YYYY-MM-DD",
      "validation": {
        "min_date": "start_date",
        "max_date": "today"
      }
    },
    "currencies": {
      "type": "array",
      "required": true,
      "description": "货币类型列表",
      "allowed_values": ["PHP", "INR", "USD", "CNY", "THB", "EUR", "JPY"],
      "min_items": 1,
      "max_items": 5
    },
    "data_type": {
      "type": "enum",
      "required": false,
      "description": "数据类型",
      "allowed_values": ["transaction", "revenue", "exchange_rate", "all"],
      "default": "all"
    }
  },
  
  "database_config": {
    "primary_table": "currency_transactions",
    "related_tables": ["exchange_rates", "merchant_info"],
    "indexes": ["created_at", "currency", "merchant_id"]
  },
  
  "query_template": {
    "base_query": "SELECT DATE(ct.created_at) as transaction_date, ct.currency, SUM(ct.amount) as total_amount, COUNT(*) as transaction_count, AVG(er.rate) as avg_exchange_rate, SUM(ct.amount * er.rate) as usd_equivalent FROM currency_transactions ct LEFT JOIN exchange_rates er ON ct.currency = er.currency AND DATE(ct.created_at) = DATE(er.rate_date) WHERE DATE(ct.created_at) BETWEEN '{start_date}' AND '{end_date}' AND ct.currency IN ({currencies}) GROUP BY DATE(ct.created_at), ct.currency ORDER BY transaction_date, ct.currency",
    
    "conditional_queries": {
      "transaction": "SELECT * FROM currency_transactions WHERE DATE(created_at) BETWEEN '{start_date}' AND '{end_date}' AND currency IN ({currencies})",
      "revenue": "SELECT DATE(created_at) as date, currency, SUM(revenue_amount) as total_revenue FROM revenue_records WHERE DATE(created_at) BETWEEN '{start_date}' AND '{end_date}' AND currency IN ({currencies}) GROUP BY DATE(created_at), currency",
      "exchange_rate": "SELECT rate_date, currency, rate FROM exchange_rates WHERE rate_date BETWEEN '{start_date}' AND '{end_date}' AND currency IN ({currencies})"
    }
  },
  
  "data_processing": {
    "aggregation_rules": [
      {
        "field": "total_amount",
        "operation": "sum",
        "group_by": ["transaction_date", "currency"]
      },
      {
        "field": "transaction_count",
        "operation": "count",
        "group_by": ["transaction_date", "currency"]
      }
    ],
    
    "calculated_fields": [
      {
        "name": "daily_growth_rate",
        "formula": "(current_day_amount - previous_day_amount) / previous_day_amount * 100"
      },
      {
        "name": "currency_percentage",
        "formula": "currency_amount / total_amount * 100"
      }
    ]
  },
  
  "export_rules": {
    "default_format": "excel",
    "filename_template": "currency_data_{start_date}_to_{end_date}_{timestamp}.xlsx",
    
    "excel_config": {
      "sheets": [
        {
          "name": "数据汇总",
          "data_source": "main_query",
          "include_charts": true
        },
        {
          "name": "按货币统计",
          "data_source": "currency_summary",
          "pivot_table": true
        },
        {
          "name": "趋势分析",
          "data_source": "trend_analysis",
          "charts": ["line_chart", "bar_chart"]
        }
      ],
      
      "charts": [
        {
          "type": "line",
          "title": "货币交易趋势图",
          "x_axis": "transaction_date",
          "y_axis": "total_amount",
          "series": "currency"
        },
        {
          "type": "pie",
          "title": "货币占比分布",
          "data_field": "currency_percentage",
          "label_field": "currency"
        }
      ]
    }
  },
  
  "response_format": {
    "success": {
      "status": "success",
      "message": "时间范围数据查询完成",
      "data": {
        "query_info": {
          "start_date": "{start_date}",
          "end_date": "{end_date}",
          "currencies": "{currencies}",
          "total_records": "{record_count}"
        },
        "summary": {
          "total_amount_by_currency": {},
          "daily_averages": {},
          "growth_trends": {}
        },
        "detailed_data": [],
        "export_file": {
          "filename": "{export_filename}",
          "download_url": "{download_url}",
          "file_size": "{file_size}"
        }
      }
    },
    "error": {
      "status": "error",
      "message": "查询失败：{error_message}",
      "error_code": "{error_code}",
      "suggestions": []
    }
  },
  
  "example_inputs": [
    {
      "text": "我要1号到31号的PHP跟INR数据",
      "parsed_parameters": {
        "start_date": "2024-01-01",
        "end_date": "2024-01-31",
        "currencies": ["PHP", "INR"]
      }
    },
    {
      "text": "本月的美元和人民币交易数据",
      "parsed_parameters": {
        "time_period": "current_month",
        "currencies": ["USD", "CNY"]
      }
    },
    {
      "text": "查询12月1日到12月15日的泰铢收入数据",
      "parsed_parameters": {
        "start_date": "2024-12-01",
        "end_date": "2024-12-15",
        "currencies": ["THB"],
        "data_type": "revenue"
      }
    }
  ]
}