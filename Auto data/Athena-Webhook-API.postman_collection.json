{
  "info": {
    "name": "Athena Webhook API",
    "description": "用于 n8n 集成的 Athena 查询 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "value",
        "value": "{{API_KEY}}",
        "type": "string"
      },
      {
        "key": "key",
        "value": "X-API-Key",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/health",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "health"]
        },
        "description": "检查 Webhook API 健康状态"
      }
    },
    {
      "name": "2. SQL Query - Simple",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sql\": \"SELECT 1 as test_column, 'Hello World' as message, NOW() as current_time\",\n  \"maxRows\": 10\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/query/sql",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "query", "sql"]
        },
        "description": "执行简单的 SQL 查询"
      }
    },
    {
      "name": "3. SQL Query - With Database",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sql\": \"SELECT * FROM users WHERE status = 'active' LIMIT 100\",\n  \"database\": \"production_db\",\n  \"timeout\": 60000,\n  \"maxRows\": 100\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/query/sql",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "query", "sql"]
        },
        "description": "带数据库参数的 SQL 查询"
      }
    },
    {
      "name": "4. SQL Query - Count Records",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sql\": \"SELECT COUNT(*) as total_users, COUNT(DISTINCT user_id) as unique_users FROM user_activity WHERE DATE(activity_date) >= DATE_SUB(CURDATE(), INTERVAL 7 DAY)\",\n  \"database\": \"analytics_db\",\n  \"maxRows\": 10\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/query/sql",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "query", "sql"]
        },
        "description": "统计最近7天的活跃用户"
      }
    },
    {
      "name": "5. Natural Language Query",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"查询最近7天的活跃用户数\",\n  \"timeout\": 120000,\n  \"maxRows\": 100\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/query/natural",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "query", "natural"]
        },
        "description": "使用自然语言查询"
      }
    },
    {
      "name": "6. Quick Query (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/query/quick?sql=SELECT 1 as number, 'Quick Query' as message&apiKey={{API_KEY}}",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "query", "quick"],
          "query": [
            {
              "key": "sql",
              "value": "SELECT 1 as number, 'Quick Query' as message"
            },
            {
              "key": "apiKey",
              "value": "{{API_KEY}}"
            }
          ]
        },
        "description": "快速查询（GET 方法）"
      }
    },
    {
      "name": "7. Quick Query - Count",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/query/quick?sql=SELECT COUNT(*) as total FROM users&database=production_db&apiKey={{API_KEY}}",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "query", "quick"],
          "query": [
            {
              "key": "sql",
              "value": "SELECT COUNT(*) as total FROM users"
            },
            {
              "key": "database",
              "value": "production_db"
            },
            {
              "key": "apiKey",
              "value": "{{API_KEY}}"
            }
          ]
        },
        "description": "快速统计查询"
      }
    },
    {
      "name": "Auth - No API Key (Should Fail)",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/health",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "health"]
        },
        "description": "测试未提供 API Key 的情况（应返回 401）"
      }
    },
    {
      "name": "Auth - Invalid API Key (Should Fail)",
      "request": {
        "auth": {
          "type": "apikey",
          "apikey": [
            {
              "key": "value",
              "value": "invalid-key-123",
              "type": "string"
            },
            {
              "key": "key",
              "value": "X-API-Key",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/webhook/health",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "webhook", "health"]
        },
        "description": "测试无效 API Key（应返回 403）"
      }
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "API_KEY",
      "value": "your-api-key-here",
      "type": "string"
    }
  ]
}








